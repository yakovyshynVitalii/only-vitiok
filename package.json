{
  "name": "only-vitiok-app",
  "version": "2.0.0",
  "private": true,
  "description": "Nuxt app for media analysis and upload pipeline",
  "scripts": {
    "dev": "nuxt dev --clear",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "clean": "rm -rf .nuxt .output",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "login": "node scripts/login.js",
    "generate-config": "node scripts/generate-config.js",
    "upload": "node scripts/upload.js",
    "add-tags": "node scripts/add-tags.js",
    "vitiok": "node vitiok-pipeline.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.15.1",
  "dependencies": {
    "@fontsource/roboto": "^5.2.9",
    "@nuxt/ui": "^3.3.3",
    "dotenv": "^17.3.1",
    "google-trends-api": "^4.9.2",
    "nuxt": "^3.17.7",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.1",
    "h3": "1.15.9",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.1.2"
  }
}
